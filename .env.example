# Copy to .env for local development only. Never commit the copied file.

# Application
NEBULA_ENV=development
NEBULA_LOG_LEVEL=INFO
NEBULA_API_PUBLIC_URL=http://localhost:8000
NEBULA_ADMIN_PUBLIC_URL=http://localhost:3000
NEBULA_ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL and Redis
POSTGRES_DB=nebula
POSTGRES_USER=nebula
POSTGRES_PASSWORD=replace-local-only
DATABASE_URL=postgresql+asyncpg://nebula:replace-local-only@postgres:5432/nebula
REDIS_URL=redis://redis:6379/0

# Authentication (production uses mounted files or a secret manager)
NEBULA_JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
NEBULA_JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
NEBULA_TOKEN_PEPPER_FILE=/run/secrets/token_pepper
NEBULA_MFA_ENCRYPTION_KEY_FILE=/run/secrets/mfa_encryption_key
NEBULA_ACCESS_TOKEN_TTL_SECONDS=900
NEBULA_REFRESH_TOKEN_TTL_DAYS=30
NEBULA_ACTIVATION_TOKEN_TTL_HOURS=24
NEBULA_PASSWORD_RESET_TTL_MINUTES=30
NEBULA_ADMIN_SESSION_TTL_MINUTES=30

# Initial administrator (password is entered interactively by the seed command)
NEBULA_ADMIN_EMAIL=admin@example.com

# Email: smtp or resend
NEBULA_EMAIL_PROVIDER=smtp
NEBULA_EMAIL_FROM=Nebula VPN <no-reply@example.com>
NEBULA_SMTP_HOST=mailpit
NEBULA_SMTP_PORT=1025
NEBULA_SMTP_USERNAME=
NEBULA_SMTP_PASSWORD_FILE=/run/secrets/smtp_password
NEBULA_SMTP_STARTTLS=false
NEBULA_RESEND_API_KEY_FILE=/run/secrets/resend_api_key

# API-to-agent mutual TLS
NEBULA_VPN_AGENT_URL=https://vpn-agent:9443
NEBULA_AGENT_CA_FILE=/run/secrets/agent_ca
NEBULA_AGENT_CLIENT_CERT_FILE=/run/secrets/agent_client_cert
NEBULA_AGENT_CLIENT_KEY_FILE=/run/secrets/agent_client_key

# WireGuard agent (host-side only)
NEBULA_WG_INTERFACE=wg0
NEBULA_WG_SERVER_PRIVATE_KEY_FILE=/run/nebula-secrets/wireguard_server_private_key
NEBULA_WG_SERVER_ADDRESS=10.77.0.1/24
NEBULA_WG_CLIENT_POOL=10.77.0.0/24
NEBULA_WG_LISTEN_PORT=51820
NEBULA_WG_PUBLIC_ENDPOINT=vpn.example.com:51820
NEBULA_WG_CLIENT_DNS=1.1.1.1
NEBULA_WG_CLIENT_ALLOWED_IPS=0.0.0.0/0,::/0
NEBULA_WG_PERSISTENT_KEEPALIVE_SECONDS=25

# Reverse proxy and TLS
NEBULA_DOMAIN=vpn.example.com
NEBULA_ACME_EMAIL=ops@example.com

# Retention and operational limits
NEBULA_AUDIT_RETENTION_DAYS=365
NEBULA_AUTH_LOG_RETENTION_DAYS=90
NEBULA_EMAIL_RETENTION_DAYS=90
NEBULA_ACCOUNT_REQUEST_RATE_LIMIT=5/hour
NEBULA_LOGIN_RATE_LIMIT=10/15minutes
NEBULA_MAX_REQUEST_BYTES=1048576

# Encrypted, off-host backups
NEBULA_BACKUP_SCHEDULE=0 2 * * *
NEBULA_BACKUP_RETENTION_DAYS=30
NEBULA_BACKUP_AGE_RECIPIENT=age1replace_with_public_recipient
NEBULA_BACKUP_REMOTE=

